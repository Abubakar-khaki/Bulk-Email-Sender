# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bulk_email_sender
DATABASE_ASYNC_URL=postgresql+asyncpg://user:password@localhost:5432/bulk_email_sender

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Bulk Email Sender

# SendGrid (alternative to SMTP)
SENDGRID_API_KEY=your-sendgrid-key

# Application
APP_NAME=Bulk Email Sender Pro
APP_VERSION=2.0.0
DEBUG=True
ENVIRONMENT=development

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000

# Email Limits
MAX_RECIPIENTS_PER_CAMPAIGN=10000
MAX_CAMPAIGNS_PER_DAY=100
EMAILS_PER_SECOND=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log